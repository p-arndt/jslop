{
  "name": "jslop",
  "version": "0.0.0",
  "private": true,
  "description": "JSlop framework monorepo",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev:counter": "pnpm --filter @jslop/example-counter run dev",
    "dev:neon": "pnpm --filter @jslop/example-neon-lab run dev",
    "dev:tasks": "pnpm --filter @jslop/example-tasks run dev",
    "bench": "pnpm --filter @jslop/benchmarks run bench",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@11.0.9"
}
